{
  "name": "main-v1-required-checks",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request"
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "lint"
          },
          {
            "context": "typecheck"
          },
          {
            "context": "test"
          },
          {
            "context": "build"
          }
        ]
      }
    }
  ],
  "bypass_actors": []
}
